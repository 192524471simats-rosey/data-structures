#include<stdio.h>

int main()
{
    char infix[20],postfix[20];
    int i,j=0;

    printf("Enter expression: ");
    scanf("%s",infix);

    for(i=0;infix[i]!='\0';i++)
    {
        if((infix[i]>='A'&&infix[i]<='Z')||
           (infix[i]>='a'&&infix[i]<='z'))
        {
            postfix[j++]=infix[i];
        }
    }

    postfix[j]='\0';

    printf("Postfix = %s",postfix);

    return 0;
}
