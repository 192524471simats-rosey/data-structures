#include<stdio.h>

#define MAX 5

int stack[MAX], top=-1;

int main()
{
    int ch,item,i;

    do
    {
        printf("\n1.Push\n2.Pop\n3.Peek\n4.Display\n5.Exit\n");
        scanf("%d",&ch);

        switch(ch)
        {
            case 1:
                if(top==MAX-1)
                    printf("Stack Overflow");
                else
                {
                    printf("Enter element: ");
                    scanf("%d",&item);
                    stack[++top]=item;
                }
                break;

            case 2:
                if(top==-1)
                    printf("Stack Underflow");
                else
                    printf("Deleted = %d",stack[top--]);
                break;

            case 3:
                if(top==-1)
                    printf("Stack Empty");
                else
                    printf("Top = %d",stack[top]);
                break;

            case 4:
                for(i=top;i>=0;i--)
                    printf("%d\n",stack[i]);
                break;
        }

    }while(ch!=5);

    return 0;
}
