#include<stdio.h>

#define MAX 5

int q[MAX],front=-1,rear=-1;

int main()
{
    int ch,item,i;

    do
    {
        printf("\n1.Enqueue\n2.Dequeue\n3.Display\n4.Exit\n");
        scanf("%d",&ch);

        switch(ch)
        {
            case 1:
                if(rear==MAX-1)
                    printf("Queue Full");
                else
                {
                    if(front==-1)
                        front=0;
                    printf("Enter element: ");
                    scanf("%d",&item);
                    q[++rear]=item;
                }
                break;

            case 2:
                if(front==-1||front>rear)
                    printf("Queue Empty");
                else
                    printf("Deleted=%d",q[front++]);
                break;

            case 3:
                for(i=front;i<=rear;i++)
                    printf("%d ",q[i]);
                break;
        }

    }while(ch!=4);

    return 0;
}
